{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for penna document windows",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-title",
    "core:webview:default",
    "core:event:default",
    "store:default",
    "opener:default",
    "dialog:default"
  ]
}
